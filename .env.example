# Be Prime — 環境変数
# このファイルをコピーしてプロジェクト直下に `.env` を作成する
#   cp .env.example .env
#
# Creators API のキーは Amazonアソシエイト → ツール → Creators API で発行
# @see https://affiliate.amazon.co.jp/creatorsapi

# アソシエイトタグ（公開可。本文リンクの tag= にも使われる）
PUBLIC_AMAZON_ASSOCIATE_TAG=be-prime-22

# Creators API（ローカルビルド・dev 用。Git にはコミットしない）
# 日本（v3.3）向け。トークンは api.amazon.co.jp を使用
AMAZON_CREATORS_API_ACCESS_KEY=
AMAZON_CREATORS_API_SECRET_KEY=
AMAZON_CREATORS_API_PARTNER_TAG=be-prime-22
