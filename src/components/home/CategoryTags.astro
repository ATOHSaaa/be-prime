---
import { categories } from '@/config/site';
import type { CategoryId } from '@/config/site';
import { path } from '@/lib/paths';

const categoryIds = Object.keys(categories) as CategoryId[];
---

<nav class="category-tags" aria-label="カテゴリ">
  <ul class="category-tags__list">
    {
      categoryIds.map((id) => (
        <li>
          <a href={path(`/category/${id}/`)} class="category-tags__link">
            #{categories[id].shortName}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
