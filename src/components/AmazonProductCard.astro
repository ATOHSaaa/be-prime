---
import SaleBadge from '@/components/SaleBadge.astro';
import type { CreatorsProduct } from '@/lib/amazon';
import { formatPriceYen } from '@/lib/format-price';

interface Props {
  product: CreatorsProduct;
  label?: string;
  note?: string;
}

const { product, label, note } = Astro.props;
const displayPrice = formatPriceYen(product.price);
---

<article class="amazon-product-card">
  <a
    class="amazon-product-card__link"
    href={product.detailPageUrl}
    rel="nofollow sponsored noopener"
    target="_blank"
  >
    {product.imageUrl && (
      <div class="amazon-product-card__image-wrap">
        <img
          src={product.imageUrl}
          alt=""
          width="160"
          height="160"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="amazon-product-card__body">
      <div class="amazon-product-card__badges">
        {product.savings && <SaleBadge label={product.savings} variant="sale" />}
        {product.isPrime && <SaleBadge label="Prime" variant="prime" />}
      </div>
      {label && <p class="amazon-product-card__label">{label}</p>}
      <h3 class="amazon-product-card__title">{product.title}</h3>
      {displayPrice ? (
        <p class="amazon-product-card__price">{displayPrice}</p>
      ) : (
        <p class="amazon-product-card__price amazon-product-card__price--muted">
          価格は商品ページでご確認ください
        </p>
      )}
      {note && <p class="amazon-product-card__note">{note}</p>}
      <p class="amazon-product-card__cta">Amazon.co.jpで見る</p>
    </div>
  </a>
</article>
