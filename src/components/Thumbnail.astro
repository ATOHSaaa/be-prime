---
import type { Post } from '@/lib/posts';
import type { PostThumbnail } from '@/lib/post-thumbnail';
import {
  getThumbnailCoverUrl,
  resolvePostThumbnail,
} from '@/lib/post-thumbnail';
import { categories, ctas, thumbnailBrands } from '@/config/site';
import type { CategoryId, CtaId, ThumbnailBrandId } from '@/config/site';

interface Props {
  post: Post;
  /** CSS aspect-ratio（例: "16 / 10"） */
  ratio?: string;
  /**
   * false = カード本文にタイトルがあるとき（Feature等）。
   * ガイド記事は装飾サムネのみ表示。
   */
  showTitle?: boolean;
  /** サイドバー Ranking 用の超小型表示 */
  variant?: 'default' | 'ranking';
  /** large = モザイクをフル表示、compact = 代表1枚のみ */
  display?: 'large' | 'compact';
  thumbnail?: PostThumbnail;
}

const {
  post,
  ratio = '16 / 10',
  showTitle = false,
  variant = 'default',
  display = 'compact',
  thumbnail: thumbnailProp,
} = Astro.props;
const cat = categories[post.data.category as CategoryId];
const thumbnail = thumbnailProp ?? resolvePostThumbnail(post);
const coverImage = getThumbnailCoverUrl(thumbnail);
const isRanking = variant === 'ranking';
const isBrand = thumbnail?.kind === 'brand';
const brand =
  isBrand && thumbnail.kind === 'brand'
    ? thumbnailBrands[thumbnail.brand as ThumbnailBrandId]
    : undefined;
const brandBadge =
  isBrand && thumbnail.kind === 'brand' ? thumbnail.badge : undefined;
const showMosaic =
  thumbnail?.kind === 'mosaic' && display === 'large' && !isRanking;
const mosaicCount = showMosaic ? thumbnail.imageUrls.length : 0;
const showPrices =
  thumbnail?.kind === 'product' &&
  (thumbnail.price || thumbnail.referencePrice);
const guideKicker =
  post.data.category === 'deals' ? '特集・ガイド' : cat.shortName;
const guideBadge = post.data.cta
  ? ctas[post.data.cta as CtaId]?.shortName
  : undefined;
const rankingGuideLabel =
  post.data.category === 'deals' ? '特集' : cat.shortName;
---

<div
  class:list={[
    'thumb',
    isRanking && 'thumb--ranking',
    isBrand && 'thumb--brand',
  ]}
  style={`--thumb-ratio: ${ratio};`}
>
  {
    isRanking ? (
      thumbnail?.kind === 'product' ? (
        <div
          class={`thumb__ranking thumb__ranking--product thumb__ranking--${post.data.category}`}
          aria-hidden="true"
        >
          <img
            class="thumb__ranking-img"
            src={thumbnail.imageUrl}
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
      ) : isBrand && brand ? (
        <div class="thumb__brand thumb__brand--compact" aria-hidden="true">
          <p class="thumb__brand-logo">
            <span class="thumb__brand-logo-prime">{brand.labelPrime}</span>
            <span class="thumb__brand-logo-video">{brand.labelVideo}</span>
          </p>
        </div>
      ) : coverImage ? (
        <img
          class="thumb__ranking-img thumb__ranking-img--cover"
          src={coverImage}
          alt=""
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class={`thumb__ranking thumb__ranking--guide thumb__ranking--${post.data.category}`}
          aria-hidden="true"
        >
          <div class="thumb__ranking-stack">
            <span class="thumb__ranking-icon" aria-hidden="true" />
            <span class="thumb__ranking-label">{rankingGuideLabel}</span>
          </div>
        </div>
      )
    ) : showMosaic ? (
      <div
        class:list={[
          'thumb__mosaic',
          `thumb__mosaic--${mosaicCount}`,
        ]}
        aria-hidden="true"
      >
        {
          thumbnail.imageUrls.map((url) => (
            <img
              class="thumb__mosaic-item"
              src={url}
              alt=""
              loading="lazy"
              decoding="async"
            />
          ))
        }
      </div>
    ) : thumbnail?.kind === 'product' ? (
      <div
        class={`thumb__product thumb__product--${post.data.category}`}
        aria-hidden="true"
      >
        {thumbnail.savings && (
          <span class="thumb__product-badge">{thumbnail.savings}</span>
        )}
        <div class="thumb__product-visual">
          <img
            class="thumb__product-img"
            src={thumbnail.imageUrl}
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        {showPrices && (
          <div class="thumb__product-prices">
            {thumbnail.referencePrice && (
              <span class="thumb__product-ref">{thumbnail.referencePrice}</span>
            )}
            {thumbnail.price && (
              <span class="thumb__product-sale">{thumbnail.price}</span>
            )}
          </div>
        )}
      </div>
    ) : isBrand && brand ? (
      <div class="thumb__brand" aria-hidden="true">
        {brandBadge && (
          <span class="thumb__brand-badge">{brandBadge}</span>
        )}
        <div class="thumb__brand-glow" aria-hidden="true" />
        <div class="thumb__brand-stack">
          <span class="thumb__brand-play" aria-hidden="true" />
          <p class="thumb__brand-logo">
            <span class="thumb__brand-logo-prime">{brand.labelPrime}</span>
            <span class="thumb__brand-logo-video">{brand.labelVideo}</span>
          </p>
        </div>
      </div>
    ) : coverImage ? (
      <img
        class="thumb__img"
        src={coverImage}
        alt=""
        loading="lazy"
        decoding="async"
      />
    ) : showTitle ? (
      <div
        class={`thumb__ph thumb__ph--${post.data.category}`}
        aria-hidden="true"
      >
        <span class="thumb__ph-cat">{cat.shortName}</span>
        <span class="thumb__ph-title">{post.data.title}</span>
      </div>
    ) : (
      <div
        class={`thumb__guide thumb__guide--${post.data.category}`}
        aria-hidden="true"
      >
        {guideBadge && (
          <span class="thumb__guide-badge">{guideBadge}</span>
        )}
        <span class="thumb__guide-icon" aria-hidden="true" />
        <span class="thumb__guide-label">{guideKicker}</span>
      </div>
    )
  }
</div>
