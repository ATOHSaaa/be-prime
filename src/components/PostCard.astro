---
import type { CollectionEntry } from 'astro:content';
import Thumbnail from '@/components/Thumbnail.astro';
import { formatDate } from '@/lib/posts';
import { categories } from '@/config/site';
import type { CategoryId } from '@/config/site';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
const href = `/posts/${post.id}/`;
const cat = categories[category as CategoryId];
---

<a href={href} class="post-card">
  <div class="post-card__thumb">
    <Thumbnail post={post} ratio="16 / 10" showTitle={false} />
  </div>
  <div class="post-card__body">
    <p class="post-card__meta">
      <span class={`category-badge category-badge--${category}`}>
        {cat.shortName}
      </span>
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
    </p>
    <h2 class="post-card__title">{title}</h2>
    {description && <p class="post-card__desc">{description}</p>}
  </div>
</a>
