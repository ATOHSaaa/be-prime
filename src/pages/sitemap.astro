---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedPosts } from '@/lib/posts';
import { staticSitemapPages } from '@/lib/sitemap-pages';
import { site } from '@/config/site';
import { path } from '@/lib/paths';

const posts = await getPublishedPosts();
const xmlSitemapUrl = new URL('/sitemap-index.xml', site.url).href;
---

<BaseLayout
  title="サイトマップ"
  description="アマサブのページ一覧です。"
  pathname="/sitemap/"
>
  <h1 class="page-title">サイトマップ</h1>
  <div class="container--narrow">
    <h2>固定ページ</h2>
    <ul>
      {staticSitemapPages.map((page) => (
        <li>
          <a href={path(page.href)}>{page.label}</a>
        </li>
      ))}
    </ul>
    <h2>記事</h2>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={path(`/posts/${post.id}/`)}>{post.data.title}</a>
        </li>
      ))}
    </ul>
    <p>
      <a href={xmlSitemapUrl}>XMLサイトマップ（sitemap-index.xml）</a>（検索エンジン向け）
    </p>
  </div>
</BaseLayout>
