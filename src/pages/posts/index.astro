---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import CategoryTags from '@/components/home/CategoryTags.astro';
import { getPublishedPosts } from '@/lib/posts';
import { site } from '@/config/site';

const posts = await getPublishedPosts();
---

<BaseLayout
  title="記事一覧"
  description={`${site.name}の記事一覧。Amazonセール・Prime Day・タイムセールの攻略とおすすめ商品を掲載しています。`}
  pathname="/posts/"
>
  <CategoryTags />
  <h1 class="page-title">記事一覧</h1>
  {posts.length === 0 ? (
    <p>記事を準備中です。</p>
  ) : (
    <div class="post-list">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  )}
</BaseLayout>
